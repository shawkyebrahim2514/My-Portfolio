---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import Aurora from '../components/reactbits/Aurora';
import FadeIn from '../components/motion/FadeIn';
import { proseComponents, LinkButton } from '../components/prose';
import { getCollection, render } from 'astro:content';

const [about] = await getCollection('about');
const { Content } = await render(about);
const data = about.data;

const contacts = (await getCollection('contacts')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<PortfolioLayout title={`${data.personName} — Portfolio`}>
  <section
    class="relative isolate -mt-4 overflow-hidden rounded-lg px-2 py-16 sm:px-6 sm:py-20"
  >
    <Aurora client:visible />
    <div class="grid items-center gap-12 md:grid-cols-[1fr_auto]">
      <FadeIn client:visible>
        <div class="flow flow-space-sm">
          <p class="eyebrow text-gradient">
            <span
              class="inline-block h-2 w-2 animate-pulse rounded-full"
              style="background: var(--vivid-pink)"></span>
            {data.salutation}
          </p>
          <h1
            class="text-balance text-5xl font-extrabold leading-[1.05] tracking-tight sm:text-6xl"
          >
            <span class="text-gradient-animated">{data.personName}</span>
          </h1>
          <p class="text-2xl font-semibold text-text sm:text-3xl">
            {data.position}
          </p>
          <p class="max-w-md text-lg text-text-muted">{data.seeking}</p>
          <div class="pt-3">
            <LinkButton href={data.resume.link} icon="doc">
              {data.resume.text}
            </LinkButton>
          </div>
        </div>
      </FadeIn>
      <FadeIn client:visible delay={0.15}>
        <div class="glow relative mx-auto w-fit">
          <div
            class="rounded-full p-[3px]"
            style="background: var(--gradient-brand)"
          >
            <img
              src={data.personImage}
              alt={data.personName}
              width="200"
              height="200"
              class="h-40 w-40 rounded-full border-4 border-bg object-cover sm:h-52 sm:w-52"
            />
          </div>
        </div>
      </FadeIn>
    </div>
  </section>

  <FadeIn client:visible>
    <article class="prose mt-12 max-w-3xl">
      <Content components={proseComponents} />
    </article>
  </FadeIn>

  <section class="mt-14">
    <h2 class="eyebrow mb-4 text-text-muted">Find me online</h2>
    <ul class="flex flex-wrap gap-3">
      {
        contacts.map((c) => (
          <li>
            <a
              href={c.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="lift inline-flex items-center gap-2 rounded-full border border-border bg-surface px-4 py-2 text-sm text-text transition-colors hover:border-accent hover:text-accent"
            >
              <img
                src={c.data.icon}
                alt=""
                width="18"
                height="18"
                class="h-[18px] w-[18px]"
              />
              {c.data.name}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</PortfolioLayout>
