---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import Aurora from '../components/reactbits/Aurora';
import FadeIn from '../components/motion/FadeIn';
import { proseComponents, LinkButton } from '../components/prose';
import { getCollection, render } from 'astro:content';

const [about] = await getCollection('about');
const { Content } = await render(about);
const data = about.data;

const contacts = (await getCollection('contacts')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<PortfolioLayout title={`${data.personName} — Portfolio`}>
  <section class="relative isolate -mt-4 overflow-hidden rounded-lg">
    <Aurora client:visible />
    <div
      class="grid items-center gap-10 px-2 py-10 sm:px-6 md:grid-cols-[1fr_auto]"
    >
      <FadeIn client:visible>
        <div class="flow flow-space-sm">
          <p class="font-mono text-sm font-medium text-accent">
            {data.salutation}
          </p>
          <h1 class="text-4xl font-bold tracking-tight text-text sm:text-5xl">
            {data.personName}
          </h1>
          <p class="text-xl text-text-muted">{data.position}</p>
          <p class="text-text-muted">{data.seeking}</p>
          <div class="pt-2">
            <LinkButton href={data.resume.link} icon="doc">
              {data.resume.text}
            </LinkButton>
          </div>
        </div>
      </FadeIn>
      <FadeIn client:visible delay={0.15}>
        <img
          src={data.personImage}
          alt={data.personName}
          width="180"
          height="180"
          class="h-36 w-36 rounded-full border border-border object-cover shadow-lg sm:h-44 sm:w-44"
        />
      </FadeIn>
    </div>
  </section>

  <FadeIn client:visible>
    <article class="prose mt-12 max-w-3xl">
      <Content components={proseComponents} />
    </article>
  </FadeIn>

  <section class="mt-14">
    <h2
      class="mb-4 text-sm font-medium uppercase tracking-widest text-text-muted"
    >
      Find me online
    </h2>
    <ul class="flex flex-wrap gap-3">
      {
        contacts.map((c) => (
          <li>
            <a
              href={c.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-4 py-2 text-sm text-text transition-colors hover:border-accent hover:text-accent"
            >
              <img
                src={c.data.icon}
                alt=""
                width="18"
                height="18"
                class="h-[18px] w-[18px]"
              />
              {c.data.name}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</PortfolioLayout>
