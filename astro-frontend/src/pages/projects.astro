---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FadeIn from '../components/motion/FadeIn';
import { proseComponents, LinkButton } from '../components/prose';
import { getCollection, render } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
const rendered = await Promise.all(
  projects.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content,
  })),
);
---

<PortfolioLayout title="Projects — Shawky Ebrahim">
  <SectionHeading
    eyebrow="Work"
    title="Projects"
    subtitle="A selection of things I've designed, built, and shipped."
  />

  <div class="flow flow-space-lg">
    {
      rendered.map(({ entry, Content }) => (
        <FadeIn client:visible>
          <article class="rounded-lg border border-border bg-surface p-6 shadow-sm transition-colors hover:border-accent">
            <div class="prose max-w-none">
              <Content components={proseComponents} />
            </div>

            {entry.data.technologies.length > 0 && (
              <ul class="mt-5 flex flex-wrap gap-2">
                {entry.data.technologies.map((tech) => (
                  <li class="rounded-full border border-border bg-surface-muted px-3 py-1 text-xs font-medium text-text-muted">
                    {tech}
                  </li>
                ))}
              </ul>
            )}

            {(entry.data.projectLink || entry.data.demoLink) && (
              <div class="mt-4 flex flex-wrap items-center">
                {entry.data.projectLink && (
                  <LinkButton href={entry.data.projectLink} icon="link">
                    Source
                  </LinkButton>
                )}
                {entry.data.demoLink && (
                  <LinkButton href={entry.data.demoLink} icon="link">
                    Live Demo
                  </LinkButton>
                )}
              </div>
            )}
          </article>
        </FadeIn>
      ))
    }
  </div>
</PortfolioLayout>
