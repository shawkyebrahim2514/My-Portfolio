---
/**
 * Section heading for portfolio pages — an eyebrow label plus a large title,
 * with an optional supporting line.
 */
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<div class="mb-10 flow flow-space-sm">
  {
    eyebrow && (
      <p class="eyebrow text-gradient">
        <span
          class="inline-block h-2 w-2 rounded-full"
          style="background: var(--vivid-pink)"
        />
        {eyebrow}
      </p>
    )
  }
  <h1
    class="text-balance text-4xl font-extrabold tracking-tight text-text sm:text-5xl"
  >
    {title}
  </h1>
  {subtitle && <p class="max-w-2xl text-lg text-text-muted">{subtitle}</p>}
</div>
