---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Content image — the legacy `![alt](url =w300|center)` token.
 * `width`/`height` cap the size (px); the image never exceeds its column.
 * Local imported images (ImageMetadata) are optimized via Astro's <Image>;
 * plain string URLs fall back to a native lazy <img>.
 */
interface Props {
  src: string | ImageMetadata;
  alt?: string;
  width?: number;
  height?: number;
  align?: 'center' | 'left' | 'right';
}

const { src, alt = '', width, height, align = 'left' } = Astro.props;

const justify =
  align === 'center' ? 'center' : align === 'right' ? 'flex-end' : 'flex-start';

const maxW = width ? `min(100%, ${width}px)` : '100%';
const maxH = height ? `${height}px` : 'auto';
const boxStyle = `max-width: ${maxW}; max-height: ${maxH}`;
const isLocal = typeof src !== 'string';
---

<span class="prose-img" style={`justify-content: ${justify}`}>
  {
    isLocal ? (
      <Image
        src={src}
        alt={alt}
        width={width}
        height={height}
        densities={[1, 2]}
        loading="lazy"
        decoding="async"
        style={boxStyle}
      />
    ) : (
      <img
        src={src}
        alt={alt}
        loading="lazy"
        decoding="async"
        style={boxStyle}
      />
    )
  }
</span>

<style>
  .prose-img {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin: 1rem 0;
  }
  .prose-img img {
    height: auto;
    border-radius: var(--rad-md);
  }
</style>
